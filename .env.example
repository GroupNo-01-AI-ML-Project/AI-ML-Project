# Example environment variables for the ICST AI Food System.
# Copy to ".env" and fill in real values. NEVER commit your real .env (it's gitignored).

# --- App security ---
# Secret used to sign auth tokens. Generate one, e.g. python -c "import secrets;print(secrets.token_hex(32))"
APP_SECRET_KEY=

# --- Gemini Vision (optional) — enables real food-image recognition ---
# Get a key from Google AI Studio (https://aistudio.google.com/app/apikey).
# Without it, image upload still works but recognition is skipped.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Runtime ---
PYTHONUNBUFFERED=1
